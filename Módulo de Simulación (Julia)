# 9. FASE 2 — IMPACTO ELÉCTRICO Y AMBIENTAL NACIONAL
#
# Traduce las trayectorias de N(t) del escenario Estrategia Integral
# en indicadores de ingeniería eléctrica y ambiental.
#
# Supuestos técnicos con sus fuentes:
#   km_anual      : recorrido anual promedio por vehículo (AgenciaSE 2025)
#   consumo_ve    : consumo específico BEV+PHEV en kWh/km (Arancibia 2025)
#   rend_ice      : rendimiento equivalente del vehículo ICE sustituido en km/L
#   fe_gasolina   : factor de emisión de la gasolina en kgCO₂/L (IPCC)
#   fac_eq        : factor de equivalencia eléctrica BEV+PHEV (1.0 = demanda plena)
#   pot_cargador  : potencia del cargador residencial Nivel 2 en kW (RIC N°15 SEC)
#   fs_ng         : factor de simultaneidad sin gestión (ISCI 2024)
#   fs_int        : factor de simultaneidad con carga inteligente BT1-SCH (ISCI 2024)
#   fe_sen_*      : factor de emisión del SEN por año (PELP 2023-2032)
#   fe_smacc_*    : factor de emisión del SEN según Plan SMACC (sensibilidad)
# ==============================================================================

println("\n" * "=" ^ 70)
println("FASE 2 — IMPACTO ELÉCTRICO Y AMBIENTAL NACIONAL")
println("Escenario principal: Estrategia Integral")
println("=" ^ 70)

const km_anual      = 15_000.0   # km/año
const consumo_ve    =      0.18  # kWh/km
const rend_ice      =     12.0   # km/L
const fe_gasolina   =      2.3   # kgCO₂/L
const fac_eq        =      1.0   # factor equivalencia BEV+PHEV
const pot_cargador  =      7.4   # kW — RIC N°15 SEC
const fs_ng         =      0.40  # factor simultaneidad no gestionada (ISCI 2024)
const fs_int        =      0.15  # factor simultaneidad carga inteligente (ISCI 2024)
const fe_sen_2030   =      0.150 # tCO₂/MWh — Caso A conservador (PELP 2023-2032)
const fe_sen_2035   =      0.100 # tCO₂/MWh — Caso A conservador (PELP 2023-2032)
const fe_smacc_2030 =      0.00437 # tCO₂eq/MWh — Caso B Plan SMACC
const fe_smacc_2035 =      0.00417 # tCO₂eq/MWh — Caso B Plan SMACC

# Energía eléctrica anual demandada por el parque N(t) [GWh/año]
# E = N × km_anual × consumo_ve / 1e6
energia_anual_gwh(N) = (N * km_anual * consumo_ve * fac_eq) / 1e6

# Potencia Coincidente de Carga [MW]
# Representa la demanda simultánea de potencia en el momento de mayor carga.
# P = N × FS × pot_cargador / 1000
# FS = 0.40: escenario sin gestión (máximo estrés en red)
# FS = 0.15: escenario con carga inteligente BT1-SCH (tarifa horaria)
potencia_coincidente(N, fs) = (N * fs * pot_cargador * fac_eq) / 1_000

# Combustible fósil desplazado [litros/año]
# Asume que cada VE reemplaza un vehículo ICE de 12 km/L
litros_desplazados(N) = (N * km_anual * fac_eq) / rend_ice

# CO₂ bruto evitado [tCO₂/año]
# Emisiones que ya no ocurren en el tubo de escape por no quemar gasolina
co2_bruto_evitado(N) = (litros_desplazados(N) * fe_gasolina) / 1_000

# CO₂ asociado al suministro eléctrico del SEN [tCO₂/año]
# Descuenta el costo ambiental de generar la electricidad que carga los VE.
# E_gwh se convierte a MWh multiplicando por 1000.
emisiones_sen(E, fe) = (E * 1_000.0) * fe

# Extracción de resultados de la Fase 1 para los hitos 2030 y 2035
s2030_INT, N2030_INT, C2030_INT = obtener_estado_en_anio(sol_INT, 2030)
s2035_INT, N2035_INT, C2035_INT = obtener_estado_en_anio(sol_INT, 2035)

