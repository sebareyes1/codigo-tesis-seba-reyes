function resolver_ruta_pln(ruta_principal::String, nombre::String)::String
    for ruta in [ruta_principal, joinpath(@__DIR__, nombre), joinpath(pwd(), nombre)]
        isfile(ruta) && return abspath(ruta)
    end
    error("No se encontró el CSV PLN. Rutas revisadas:\n" *
          join(["  - " * r for r in [ruta_principal,
                joinpath(@__DIR__, nombre), joinpath(pwd(), nombre)]], "\n"))
end

function cargar_resumen_pln(ruta::String)::SeriePLN
    lineas = [replace(l, '\ufeff' => "") for l in readlines(ruta)]
    idx = findfirst(l -> strip(l) == "#RESUMEN_ANUAL", lineas)
    isnothing(idx) && error("El CSV no contiene la marca #RESUMEN_ANUAL.")

    enc = strip.(split(strip(lineas[idx + 1]), ','))
    cols = ["Anio","IPS_Score_Promedio","IPS_Normalizado",
            "w_econom_anual","w_social_anual","w_infra_anual","N_Noticias"]
    falt = setdiff(cols, enc)
    isempty(falt) || error("Faltan columnas: $(join(falt, ", "))")
    pos = Dict(c => findfirst(==(c), enc) for c in cols)

    anios, ips, re, rs, ri = Float64[], Float64[], Float64[], Float64[], Float64[]
    for l in lineas[(idx + 2):end]
        isempty(strip(l)) && continue
        cel = strip.(split(strip(l), ','))
        length(cel) < length(enc) && continue
        try
            push!(anios, parse(Float64, cel[pos["Anio"]]))
            push!(ips,   parse(Float64, cel[pos["IPS_Normalizado"]]))
            push!(re,    parse(Float64, cel[pos["w_econom_anual"]]))
            push!(rs,    parse(Float64, cel[pos["w_social_anual"]]))
            push!(ri,    parse(Float64, cel[pos["w_infra_anual"]]))
        catch err
            @warn "Fila omitida" l exception=(err, catch_backtrace())
        end
    end
    isempty(anios) && error("No hay filas anuales válidas en $ruta.")

    ord = sortperm(anios)
    length(unique(anios[ord])) == length(anios) ||
        error("Años duplicados en el resumen anual.")
    return SeriePLN(anios[ord], ips[ord], re[ord], rs[ord], ri[ord])
end

function interpolar_lineal_hold(t::Real, xs::Vector{Float64}, ys::Vector{Float64})
    tt = Float64(t)
    tt <= xs[1]   && return ys[1]
    tt >= xs[end] && return ys[end]
    i = searchsortedlast(xs, tt)
    return ys[i] + (ys[i+1] - ys[i]) * (tt - xs[i]) / (xs[i+1] - xs[i])
end

