E2035     = energia_anual_gwh(N2035_INT)
P2026_ng  = potencia_coincidente(N2026,     fs_ng)
P2030_ng  = potencia_coincidente(N2030_INT, fs_ng)
P2035_ng  = potencia_coincidente(N2035_INT, fs_ng)
P2026_int = potencia_coincidente(N2026,     fs_int)
P2030_int = potencia_coincidente(N2030_INT, fs_int)
P2035_int = potencia_coincidente(N2035_INT, fs_int)

L2030 = litros_desplazados(N2030_INT)
L2035 = litros_desplazados(N2035_INT)

CO2_bruto_2030  = co2_bruto_evitado(N2030_INT)
CO2_bruto_2035  = co2_bruto_evitado(N2035_INT)

# Caso A: factor de emisión conservador (PELP 2023-2032)
CO2_senA_2030   = emisiones_sen(E2030, fe_sen_2030)
CO2_senA_2035   = emisiones_sen(E2035, fe_sen_2035)
CO2_netoA_2030  = CO2_bruto_2030 - CO2_senA_2030  # beneficio neto real
CO2_netoA_2035  = CO2_bruto_2035 - CO2_senA_2035
desc_A_2030     = CO2_senA_2030 / CO2_bruto_2030 * 100  # % de descuento
desc_A_2035     = CO2_senA_2035 / CO2_bruto_2035 * 100

# Caso B: sensibilidad con factor de emisión Plan SMACC (escenario optimista)
CO2_senB_2030   = emisiones_sen(E2030, fe_smacc_2030)
CO2_senB_2035   = emisiones_sen(E2035, fe_smacc_2035)
CO2_netoB_2030  = CO2_bruto_2030 - CO2_senB_2030
CO2_netoB_2035  = CO2_bruto_2035 - CO2_senB_2035
desc_B_2030     = CO2_senB_2030 / CO2_bruto_2030 * 100
desc_B_2035     = CO2_senB_2035 / CO2_bruto_2035 * 100

