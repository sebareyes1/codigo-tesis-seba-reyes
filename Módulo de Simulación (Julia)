# │ BAU                  │ 1.00  │ 1.00   │ 1.00  │ 1.00   │ 20 carg/año      │
# │ Impulso Económico    │ 1.20  │ 1.05   │ 1.15  │ 0.90   │ 100 carg/año     │
# │ Estrategia Integral  │ 1.30  │ 1.30   │ 1.25  │ 0.75   │ 250 carg/año     │
# └──────────────────────┴───────┴────────┴───────┴────────┴──────────────────┘
const escenarios = [
    EscenarioMesa2("BAU",                 :BAU,     1.00,1.00,1.00,1.00, 20.0),
    EscenarioMesa2("Impulso Económico",   :IMPULSO, 1.20,1.05,1.15,0.90,100.0),
