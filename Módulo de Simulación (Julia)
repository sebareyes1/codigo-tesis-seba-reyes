end

# ==============================================================================
# 3. STRUCT DE ESCENARIO
#
# Cada escenario define los multiplicadores de política e infraestructura
# y el flujo anual de inversión pública en cargadores (carg/año).
#
# Campos:
#   F_pol            : multiplicador del coeficiente de innovación p(t)
#                      representa la intensidad relativa de políticas de apoyo
#   F_infra          : multiplicador del factor infraestructura en q(t)
#                      representa el ritmo de expansión de la red de carga
#   F_IPS            : escala la sensibilidad del modelo al IPS
#   B_eAHP           : factor de barreras percibidas [0,1]
#                      1.0 = fricción máxima, 0.75 = 25% de barreras removidas
#   inversion_publica: flujo físico de cargadores instalados por el Estado [carg/año]
#                      entra directamente en dC/dt (NO es un multiplicador)
# ==============================================================================

struct EscenarioMesa2
    nombre::String
    simbolo::Symbol
    F_pol::Float64
    F_infra::Float64
    F_IPS::Float64
    B_eAHP::Float64
    inversion_publica::Float64
end

# Tabla de escenarios:
# ┌──────────────────────┬───────┬────────┬───────┬────────┬──────────────────┐
