# ==============================================================================
# 4. MODELO STOCK AND FLOW
# ==============================================================================

function modelo_stockflow!(du, u, esc::EscenarioMesa2, t)
    s = clamp(u[1], 0.0, 1.0)
    N = max(u[2], 0.0)
    C = max(u[3], 0.0)

    # Tramo quiebre normativo: t >= 2035
    # lambda_eff: chatarrización solo activa post-2035 en QN
    # → antes de 2035 el QN se comporta idéntico a Estrategia Integral
    if esc.quiebre_normativo && t >= 2035.0
        du[1] = 0.0
        du[2] = VENTAS_ANUALES - esc.lambda * N
        du[3] = esc.inversion_publica + 0.005 * N
        return
    end

    # Tramo normal: Bass con fricción dinámica
    ips_val = get_dynamic_ips(t)
    sig     = get_dynamic_semantic_signals(t)

    mult_ips        = clamp(1.0 + 0.3 * ips_val * esc.F_IPS, 0.50, 1.50)
    mult_infra_fis  = 1.0 + 0.5 * ((C / 5_000.0) / (1.0 + C / 5_000.0)) * esc.F_infra
    mult_barrera    = 1.0 / max(esc.B_eAHP, 0.01)

    w_eco_dyn   = clamp(W_ECO   * (1.0 + sig.econom), 0.0, 1.0)
    w_soc_dyn   = clamp(W_SOC   * (1.0 + sig.social), 0.0, 1.0)
    w_infra_dyn = clamp(W_INFRA * (1.0 + sig.infra),  0.0, 1.0)

    p_eff = P0 * esc.F_pol * esc.F_infra * mult_barrera * (1.0 + w_eco_dyn + w_infra_dyn)
    q_eff = Q0 * mult_ips * mult_infra_fis * mult_barrera * (1.0 + w_soc_dyn)

    du[1] = (p_eff + q_eff * s) * (1.0 - s)

    lambda_eff = (esc.quiebre_normativo && t >= 2035.0) ? esc.lambda : 0.0
    du[2] = s * VENTAS_ANUALES - lambda_eff * N
    du[3] = esc.inversion_publica + 0.005 * N
end

# ==============================================================================
# 4.1 CALLBACK — QUIEBRE NORMATIVO EN t = 2035
# Fija u[1] = 1.0 exactamente en 2035 solo para el escenario QN
# ==============================================================================

cb_quiebre = ContinuousCallback(
    (u, t, integrator) -> t - 2035.0,
    integrator -> begin
        esc = integrator.p
        esc.quiebre_normativo && (integrator.u[1] = 1.0)
    end
)

