]

# ==============================================================================
# 4. MODELO STOCK AND FLOW
#
# Sistema de tres ecuaciones diferenciales ordinarias:
#
#   u[1] = s(t) : cuota de ventas BEV+PHEV en el mercado [0,1]
#   u[2] = N(t) : parque acumulado BEV+PHEV circulante [unidades]
#   u[3] = C(t) : infraestructura de carga pública [cargadores]
#
# Ecuación 1 — Bass sobre cuota de mercado:
#   ds/dt = [p(t) + q(t)·s] · (1 - s)
#   donde (1 - s) es la fracción aún no adoptada del mercado.
#   p(t): tasa de innovación efectiva (modulada por política, e-AHP y PLN)
#   q(t): tasa de imitación efectiva (modulada por infraestructura, IPS y PLN)
#
# Ecuación 2 — Stock and Flow del parque:
#   dN/dt = s(t) · VENTAS_ANUALES
#   flujo de entrada = ventas anuales × cuota enchufable
#   λ = 0 (parque joven, chatarrización despreciable en 2025-2035)
#
# Ecuación 3 — Dinámica de infraestructura:
#   dC/dt = inversion_publica + 0.005 · N(t)
#   el segundo término modela la instalación privada inducida por el parque
# ==============================================================================

function modelo_stockflow!(du, u, esc::EscenarioMesa2, t)

    # Límites físicos: s ∈ [0,1], N ≥ 0, C ≥ 0
    s = clamp(u[1], 0.0, 1.0)
    N = max(u[2], 0.0)
    C = max(u[3], 0.0)

    # ------------------------------------------------------------------
    # Señales dinámicas del módulo PLN
    # ------------------------------------------------------------------

    ips_val = get_dynamic_ips(t)      # IPS normalizado en el año t
    sig     = get_dynamic_semantic_signals(t)  # señales por dimensión

    # Multiplicador IPS sobre q(t):
    # un IPS positivo amplifica el efecto de imitación social.
    # Rango [0.50, 1.50] para evitar multiplicadores no físicos.
    mult_ips = clamp(1.0 + 0.3 * ips_val * esc.F_IPS, 0.50, 1.50)

    # ------------------------------------------------------------------
    # Factor de infraestructura física
    # ------------------------------------------------------------------

    # mult_infra_fis: función saturante de C(t) respecto a un nivel de
    # referencia C_ref = 5.000 cargadores.
    # Cuando C → 0: mult_infra_fis → 1 (sin efecto reforzador)
    # Cuando C → ∞: mult_infra_fis → 1 + 0.5·F_infra (efecto máximo)
    # Modela la reducción de ansiedad de autonomía a medida que crece la red.
    mult_infra_fis = 1.0 + 0.5 * ((C / 5_000.0) / (1.0 + C / 5_000.0)) * esc.F_infra

    # ------------------------------------------------------------------
    # Factor de barreras percibidas (e-AHP)
    # ------------------------------------------------------------------

    # mult_barrera = 1 / B_eAHP:
    # B_eAHP = 1.0 → mult_barrera = 1.0 → fricción máxima (BAU)
    # B_eAHP = 0.75 → mult_barrera ≈ 1.33 → barreras reducidas en 25%
    mult_barrera = 1.0 / max(esc.B_eAHP, 0.01)

    # ------------------------------------------------------------------
    # Pesos e-AHP dinámicos modulados por señales PLN
    # ------------------------------------------------------------------

    # Las señales PLN w_*_anual son polaridades netas (impulso - barrera).
    # Modulan los pesos base del e-AHP:
    #   señal positiva → peso efectivo aumenta → mayor presión hacia adopción
    #   señal negativa → peso efectivo disminuye → mayor resistencia
    # Clamp [0,1] para mantener los pesos como fracciones positivas.
    w_eco_dyn   = clamp(W_ECO   * (1.0 + sig.econom), 0.0, 1.0)
    w_soc_dyn   = clamp(W_SOC   * (1.0 + sig.social), 0.0, 1.0)
    w_infra_dyn = clamp(W_INFRA * (1.0 + sig.infra),  0.0, 1.0)

    # ------------------------------------------------------------------
    # Coeficientes efectivos Bass
    # ------------------------------------------------------------------

    # p_eff: tasa de innovación efectiva
    # Modulada por política (F_pol), infraestructura (F_infra),
    # barreras (mult_barrera) y señales económica e infraestructural del PLN.
    p_eff = P0 * esc.F_pol * esc.F_infra * mult_barrera *
            (1.0 + w_eco_dyn + w_infra_dyn)

    # q_eff: tasa de imitación efectiva
    # Modulada por IPS (mult_ips), infraestructura física (mult_infra_fis),
    # barreras (mult_barrera) y señal social del PLN.
    q_eff = Q0 * mult_ips * mult_infra_fis * mult_barrera *
            (1.0 + w_soc_dyn)

    # ------------------------------------------------------------------
    # Ecuaciones diferenciales
    # ------------------------------------------------------------------

    # Ec. 1: Bass sobre cuota de mercado
    # ds/dt = [p(t) + q(t)·s] · (1 - s)
    # El factor (1-s) garantiza que la cuota no supere el 100%.
    du[1] = (p_eff + q_eff * s) * (1.0 - s)

    # Ec. 2: Stock and Flow del parque acumulado
    # dN/dt = s(t) · VENTAS_ANUALES
    # Cada año ingresan al parque las unidades vendidas ese año.
    du[2] = s * VENTAS_ANUALES

    # Ec. 3: Dinámica de infraestructura de carga
    # dC/dt = inversión pública fija [carg/año] + inversión privada inducida
    # El término 0.005·N modela que por cada 200 VE en circulación
    # se instala aproximadamente 1 cargador privado.
    du[3] = esc.inversion_publica + 0.005 * N
end

# ==============================================================================
# 5. SIMULACIÓN
#
# Se resuelve el sistema ODE para cada escenario usando el solver Tsit5
# (Runge-Kutta de orden 5 con control de paso adaptativo).
# saveat=1.0 guarda el estado del sistema en cada año entero.
# ==============================================================================

println("\n" * "=" ^ 60)
println("MESA 2/3 — MODELO NACIONAL STOCK AND FLOW")
println("Escala: Chile | Horizonte: 2025–2050")
println("=" ^ 60)

soluciones = Dict{String, Any}()
for esc in escenarios
    prob = ODEProblem(modelo_stockflow!, u0, tspan, esc)
    sol  = solve(prob, Tsit5(), saveat=1.0)
    soluciones[esc.nombre] = sol
    println("  ✓ $(esc.nombre)")
end
