# 2. CARGA DEL CSV PLN
#
# El módulo Python genera un CSV con dos secciones separadas por la marca
# "#RESUMEN_ANUAL". Esta sección contiene una fila por año con:
#   - IPS_Normalizado  : índice de percepción social agregado en [-1, 1]
#   - w_econom_anual   : polaridad neta de la dimensión económica (impulso - barrera)
#   - w_social_anual   : polaridad neta de la dimensión social
#   - w_infra_anual    : polaridad neta de la dimensión infraestructural
#
# Los valores se interpolan linealmente entre años y se mantienen constantes
# fuera del rango observado (extrapolación flat).
# ==============================================================================

# Estructura que almacena las series temporales anuales del módulo PLN
struct SeriePLN
    anios::Vector{Float64}    # años disponibles (ordenados)
    ips::Vector{Float64}      # IPS normalizado por año
    r_econom::Vector{Float64} # polaridad neta dimensión económica
    r_social::Vector{Float64} # polaridad neta dimensión social
    r_infra::Vector{Float64}  # polaridad neta dimensión infraestructural
end

const NOMBRE_ARCHIVO_PLN = "input_pln_dinamico_local.csv"
const RUTA_PRINCIPAL_PLN = raw"C:\Users\sebar\Desktop\PYTHON\input_pln_dinamico_local.csv"

# Busca el CSV en tres rutas en orden de prioridad:
# 1. Ruta absoluta configurada (Windows)
# 2. Carpeta del script Julia
# 3. Directorio de trabajo actual
function resolver_ruta_pln(ruta_principal::String, nombre::String)::String
    for ruta in [ruta_principal, joinpath(@__DIR__, nombre), joinpath(pwd(), nombre)]
        isfile(ruta) && return abspath(ruta)
    end
    error("No se encontró el CSV PLN. Rutas revisadas:\n" *
          join(["  - " * r for r in [ruta_principal,
                joinpath(@__DIR__, nombre), joinpath(pwd(), nombre)]], "\n"))
end

# Lee el CSV, localiza la marca #RESUMEN_ANUAL y extrae las columnas requeridas.
# Verifica que existan todas las columnas antes de parsear.
# Retorna un SeriePLN con los datos ordenados cronológicamente.
function cargar_resumen_pln(ruta::String)::SeriePLN
    # Eliminar BOM UTF-8 si existe (frecuente en archivos generados en Windows)
    lineas = [replace(l, '\ufeff' => "") for l in readlines(ruta)]

    idx = findfirst(l -> strip(l) == "#RESUMEN_ANUAL", lineas)
    isnothing(idx) && error("El CSV no contiene la marca #RESUMEN_ANUAL.")

    enc = strip.(split(strip(lineas[idx + 1]), ','))
    cols = ["Anio","IPS_Score_Promedio","IPS_Normalizado",
            "w_econom_anual","w_social_anual","w_infra_anual","N_Noticias"]

    # Verificar que todas las columnas requeridas estén presentes
    falt = setdiff(cols, enc)
    isempty(falt) || error("Faltan columnas: $(join(falt, ", "))")
    pos = Dict(c => findfirst(==(c), enc) for c in cols)

    anios, ips, re, rs, ri = Float64[], Float64[], Float64[], Float64[], Float64[]
    for l in lineas[(idx + 2):end]
        isempty(strip(l)) && continue
        cel = strip.(split(strip(l), ','))
        length(cel) < length(enc) && continue
        try
            push!(anios, parse(Float64, cel[pos["Anio"]]))
            push!(ips,   parse(Float64, cel[pos["IPS_Normalizado"]]))
            push!(re,    parse(Float64, cel[pos["w_econom_anual"]]))
            push!(rs,    parse(Float64, cel[pos["w_social_anual"]]))
            push!(ri,    parse(Float64, cel[pos["w_infra_anual"]]))
        catch err
            @warn "Fila omitida por formato inválido" l exception=(err, catch_backtrace())
        end
    end
    isempty(anios) && error("No hay filas anuales válidas en $ruta.")

    ord = sortperm(anios)
    length(unique(anios[ord])) == length(anios) ||
        error("Años duplicados en el resumen anual.")
    return SeriePLN(anios[ord], ips[ord], re[ord], rs[ord], ri[ord])
end

# Interpolación lineal entre años observados con retención del último valor
# fuera del rango (flat extrapolation).
# Permite que el solver ODE evalúe el IPS en cualquier t continuo.
function interpolar_lineal_hold(t::Real, xs::Vector{Float64}, ys::Vector{Float64})
    tt = Float64(t)
    tt <= xs[1]   && return ys[1]    # antes del primer año: mantener primer valor
    tt >= xs[end] && return ys[end]  # después del último año: mantener último valor
    i = searchsortedlast(xs, tt)
    # Interpolación lineal entre xs[i] y xs[i+1]
    return ys[i] + (ys[i+1] - ys[i]) * (tt - xs[i]) / (xs[i+1] - xs[i])
end

# Carga efectiva del CSV y construcción de las funciones de acceso dinámico
const RUTA_PLN  = resolver_ruta_pln(RUTA_PRINCIPAL_PLN, NOMBRE_ARCHIVO_PLN)
const SERIE_PLN = cargar_resumen_pln(RUTA_PLN)

# Retorna el IPS normalizado interpolado en el tiempo t
get_dynamic_ips(t::Real) =
    interpolar_lineal_hold(t, SERIE_PLN.anios, SERIE_PLN.ips)

# Retorna la terna de señales semánticas (econom, social, infra) en el tiempo t.
# Cada señal es una polaridad neta: valor positivo = clima favorable,
# valor negativo = clima adverso para la adopción en esa dimensión.
function get_dynamic_semantic_signals(t::Real)
    (econom = interpolar_lineal_hold(t, SERIE_PLN.anios, SERIE_PLN.r_econom),
     social = interpolar_lineal_hold(t, SERIE_PLN.anios, SERIE_PLN.r_social),
     infra  = interpolar_lineal_hold(t, SERIE_PLN.anios, SERIE_PLN.r_infra))
end

