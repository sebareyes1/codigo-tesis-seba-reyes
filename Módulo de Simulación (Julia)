# Retorna la terna (s, N, C) para el año calendario indicado.
# Busca el índice exacto en sol.t usando redondeo al entero más cercano.
function obtener_estado_en_anio(sol, anio)
    idx = findfirst(t -> round(Int, t) == anio, sol.t)
    isnothing(idx) && error("Año no encontrado: $anio")
    return sol.u[idx][1], sol.u[idx][2], sol.u[idx][3]
end

# Retorna el año y la cuota s(t) del tipping point de la curva de adopción.
# El tipping point es el año de mayor aceleración de s(t), definido como
# el máximo de la derivada discreta ds/dt = diff(s).
# Es el punto de inflexión de la curva sigmoidal de Bass.
function obtener_tipping_point_cuota(sol)
    cuotas = [clamp(u[1], 0.0, 1.0) for u in sol.u]
    tasas  = diff(cuotas)     # derivada discreta anual de s(t)
    idx    = argmax(tasas)    # año de mayor aceleración
    return sol.t[idx + 1], tasas[idx], cuotas[idx + 1]
end

