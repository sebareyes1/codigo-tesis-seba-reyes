# 6. FUNCIONES DE EXTRACCIÓN
# ==============================================================================

function obtener_estado_en_anio(sol, anio_objetivo)
    idx = findfirst(t -> round(Int, t) == anio_objetivo, sol.t)
    isnothing(idx) && error("Año no encontrado: $anio_objetivo")
    s_val = sol.u[idx][1]
    N_val = sol.u[idx][2]
    C_val = sol.u[idx][3]
    return s_val, N_val, C_val
end

function obtener_N_en_anio(sol, anio_objetivo)
    _, N_val, _ = obtener_estado_en_anio(sol, anio_objetivo)
    return N_val
end

function obtener_s_en_anio(sol, anio_objetivo)
    s_val, _, _ = obtener_estado_en_anio(sol, anio_objetivo)
    return s_val
end

function obtener_tipping_point(sol)
    # Tipping point de N(t): máximo de dN/dt evaluado sobre derivada real
    tasas = [sol(t, Val{1})[2] for t in sol.t[1:end-1]]
    idx   = argmax(tasas)
    anio  = sol.t[idx]
    N_tip = sol.u[idx][2]
    return anio, tasas[idx], N_tip
end

