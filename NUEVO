# 1. PARÁMETROS GLOBALES — ESCALA NACIONAL CHILE 2025/2026
# ==============================================================================

# --- Flujo de mercado ---
# Fuente: ANAC, ventas de vehículos livianos y medianos nuevos
const VENTAS_ANUALES = 310_000.0        # unidades/año

# --- Condiciones iniciales nacionales ---
# Fuente: Informe Cero/Bajas Emisiones ANAC 2026 (BEV + PHEV enchufables)
const S0_REAL = 0.032                   # cuota inicial 3,2% de ventas
# Fuente: Ministerio de Energía, parque acumulado BEV + PHEV
const N0_REAL = 10_000.0               # vehículos circulantes
# Fuente: Plataforma EcoCarga, SEC
const C0_REAL = 1_500.0                # cargadores públicos

# --- Tasa de renovación de flota ---
# Supuesto técnico: vida útil promedio 16,7 años (INE/CEPAL)
# Justificación: en horizonte 2025-2035 la chatarrización de VE es despreciable
# porque el parque es joven; λ refleja salida de ICE del parque total
const LAMBDA = 0.060                   # año⁻¹

# --- Parámetros Bass base ---
# p0: coeficiente de innovación (adoptantes independientes)
# q0: coeficiente de imitación (adoptantes por influencia social)
const P0 = 0.0005
const Q0 = 0.180

# --- Pesos e-AHP base (desde Python/Tulio) ---
const W_SOC = 0.2884
const W_ECO = 0.2040
const W_TEC = 0.2615

# --- Horizonte de simulación ---
# u0 = [s0, N0, C0]: tres variables de estado
const u0    = [S0_REAL, N0_REAL, C0_REAL]
const tspan = (2025.0, 2050.0)

# --- Constantes de gráficos ---
