# ==============================================================================
# 4. MODELO STOCK AND FLOW — NUEVA ARQUITECTURA
#
#  Variables de estado:
#    u[1] = s(t): cuota de ventas eléctricas en ventas totales [0,1]
#    u[2] = N(t): parque acumulado de VE circulantes [unidades]
#    u[3] = C(t): infraestructura de carga pública [cargadores]
#
#  Ecuaciones:
#    ds/dt = Bass-Struben sobre cuota de mercado
#    dN/dt = s(t) × VENTAS_ANUALES − λ × N(t)
#    dC/dt = inversión pública + inversión privada inducida
# ==============================================================================

function modelo_stockflow!(du, u, esc::EscenarioMesa2, t)

    # Extraer variables de estado con protección de límites
    s = clamp(u[1], 0.0, 1.0)          # cuota entre 0% y 100%
    N = max(u[2], 0.0)                  # parque no puede ser negativo
    C = max(u[3], 0.0)                  # infraestructura no negativa

    # ------------------------------------------------------------------
    # CONTROLADOR 1: IPS — modula coeficiente de imitación q(t)
    # ------------------------------------------------------------------
    ips_val  = get_dynamic_ips(t)
    mult_ips = 1.0 + 0.3 * ips_val * esc.F_IPS

    # ------------------------------------------------------------------
    # FACTOR DE INFRAESTRUCTURA — modula adopción según cobertura
    # C_ref: nivel de referencia para saturación del efecto infraestructura
    # ------------------------------------------------------------------
    C_ref      = 5_000.0               # referencia nacional (vs 500 regional)
    ratio      = C / C_ref
    mult_infra = 1.0 + 0.5 * (ratio / (1.0 + ratio)) * esc.F_infra

    # ------------------------------------------------------------------
    # CONTROLADOR 2: e-AHP — barreras percibidas
    # Protección de división por cero
    # ------------------------------------------------------------------
    mult_barrera = 1.0 / max(esc.B_eAHP, 0.01)

    # ------------------------------------------------------------------
    # COEFICIENTES EFECTIVOS BASS
    # p(t): innovación modulada por política e infraestructura
    # q(t): imitación modulada por IPS, infraestructura y barreras
    # ------------------------------------------------------------------
    p_eff = P0 * esc.F_pol * esc.F_infra * mult_barrera * (1.0 + W_ECO + W_TEC)
    q_eff = Q0 * mult_ips  * mult_infra  * mult_barrera * (1.0 + W_SOC)

    # ------------------------------------------------------------------
    # ECUACIÓN 1: ds/dt — Bass-Struben sobre cuota de mercado
    # La cuota s evoluciona como fracción del mercado restante (1 - s)
    # ------------------------------------------------------------------
    ds = (p_eff + q_eff * s) * (1.0 - s)

    # ------------------------------------------------------------------
    # ECUACIÓN 2: dN/dt — Stock and Flow del parque acumulado
    # Entradas: ventas eléctricas = s × VENTAS_ANUALES
    # Salidas:  chatarrización = λ × N
    # ------------------------------------------------------------------
    entradas = s * VENTAS_ANUALES
    salidas  = LAMBDA * N
    dN       = entradas - salidas

    # ------------------------------------------------------------------
    # ECUACIÓN 3: dC/dt — infraestructura de carga pública
    # Inversión pública: fija por escenario (cargadores/año)
    # Inversión privada: inducida por tamaño del parque
    # ------------------------------------------------------------------
    inversion_privada = 0.005 * N
    dC = esc.inversion_publica + inversion_privada

    du[1] = ds
    du[2] = dN
    du[3] = dC
end

# ==============================================================================
# 5. SIMULACIÓN DE LOS TRES ESCENARIOS
# ==============================================================================

